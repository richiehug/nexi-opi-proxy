# Nexi OPI Proxy Docker Bundle Environment

# Override if your registry path differs from the default versioned image tag
NEXI_OPI_PROXY_IMAGE=ghcr.io/richiehug/nexi-opi-proxy:1.0.7

# Server configuration
PORT=3001
HOST=0.0.0.0

# Docker uses host networking by default in the public bundle.
# These older publish variables are ignored while docker-compose.yml uses network_mode: host.
PUBLISHED_HOST=

# Listener host for terminal communication (rarely needs change)
POS_LISTENER_HOST=0.0.0.0

# With host networking, this must match the deviceChannel1 port used by the terminal config.
DEVICE_CHANNEL1_PUBLISHED_HOST=
DEVICE_CHANNEL1_PUBLIC_PORT=4102

# ----------------------------------------
# Defaults
# ----------------------------------------

# Fallback values if not provided in request or terminal config
DEFAULT_LANGUAGE=en
DEFAULT_CURRENCY=CHF

# ----------------------------------------
# Timeouts (in milliseconds)
# ----------------------------------------

# Max idle time while waiting for terminal activity or a final OPI response
REQUEST_TIMEOUT_MS=90000

# Hard max time to wait for a final OPI response, even if device callbacks continue
REQUEST_MAX_DURATION_MS=300000

# Max time to establish the TCP connection to the terminal
OPI_CONNECT_TIMEOUT_MS=3000

# Max time for a single terminal-side action
ACTION_TIMEOUT_MS=50000

# Retry delay when terminal is temporarily unavailable
RETRY_AFTER_DEVICE_UNAVAILABLE_MS=5000

# ----------------------------------------
# Persistence and response behavior
# ----------------------------------------

STORAGE=db
DB_URL=file:/app/data/opi-proxy.sqlite
RESPONSE_MODE=async
# In async mode, briefly wait for immediate terminal rejections before returning 202
ASYNC_ACCEPT_GRACE_MS=1000
TRANSACTION_PENDING_TIMEOUT_SECONDS=300
TRANSACTION_RECOVERY_GRACE_SECONDS=30

# ----------------------------------------
# Logging
# ----------------------------------------

LOG_LEVEL=normal
TRACE_LOG_MAX_SIZE_MB=200

# ----------------------------------------
# TLS and transport
# ----------------------------------------

# Docker-friendly HTTP first-run defaults. Switch to TLS later if needed.
TLS_MODE=disabled
TLS_CERT_FILE=certs/dev.crt
TLS_KEY_FILE=certs/dev.key
ALLOW_INSECURE_REMOTE_HTTP=true

# ----------------------------------------
# Optional advanced flags
# ----------------------------------------

# Default behavior overrides (only used if not defined in terminal config)
DEFAULT_REQUEST_TRANSACTION_INFORMATION=true
DEFAULT_REQUEST_TOKEN=true
DEFAULT_REQUEST_FULL_PAN=false
DEFAULT_REQUEST_RECEIPT_HEADER=true

# Capability defaults (fallback only)
DEFAULT_ALLOW_MANUAL_PAN=false
DEFAULT_ALLOW_FORCE_ACCEPTANCE=false
